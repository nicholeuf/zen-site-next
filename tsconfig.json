{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    // Add vitest globals so `describe`, `it`, `expect` are recognized by TS
    "types": ["vitest/globals", "node"],
    "paths": {
      "@/*": ["./src/*"],
      "utils/*": ["./utils/*"],
      "test-utils": ["./utils/test-utils"],
      "types/*": ["./types/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "src/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    // Exclude Storybook config from the TypeScript build/check
    ".storybook",
    "src/**/.storybook/**"
  ]
}
